# Environment configuration
# Copy to .env and edit — .env is gitignored

# ─── Web UI / Grafana ─────────────────────────────────────────
WEBUI_SECRET_KEY=change-me-in-production
GRAFANA_PASSWORD=admin

# ─── Models pulled on first `task up` (native Ollama on host) ─────────────────────────
# Comma-separated, no spaces. Browse: https://ollama.com/library
# Includes models used by the smart router:
#   qwen2.5-coder:14b   → git commits, Rust/code-heavy routes
#   phi4:latest         → summarization, docs/prose routing
#   deepseek-coder:33b  → architecture / design (needs RAM headroom)
#   qwen2.5-coder:7b    → general code (fast), default fallback
#   gemma4:latest       → quick Q&A
#   deepseek-coder:6.7b → optional smaller coder
#   nomic-embed-text    → embeddings
DEFAULT_MODELS=qwen2.5-coder:7b,qwen2.5-coder:14b,phi4:latest,gemma4:latest,deepseek-coder:6.7b,deepseek-coder:33b,nomic-embed-text:latest

# Lighter set (less VRAM):
# DEFAULT_MODELS=qwen2.5-coder:7b,phi4:latest,gemma4:latest,nomic-embed-text:latest
