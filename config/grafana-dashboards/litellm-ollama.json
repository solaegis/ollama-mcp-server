{
  "title": "LiteLLM / Ollama Stack",
  "uid": "litellm-ollama",
  "schemaVersion": 38,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Total Requests (1h)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "sum(increase(litellm_proxy_total_requests_metric_total[1h]))",
        "legendFormat": "requests"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": 0 }] } } }
    },
    {
      "id": 2,
      "title": "Request Rate (5m)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "sum(rate(litellm_proxy_total_requests_metric_total[5m]))",
        "legendFormat": "req/s"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }] } } }
    },
    {
      "id": 3,
      "title": "Total Tokens (1h)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "sum(increase(litellm_total_tokens_metric_total[1h]))",
        "legendFormat": "tokens"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "purple", "value": 0 }] } } }
    },
    {
      "id": 4,
      "title": "Failed Requests (1h)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "sum(increase(litellm_proxy_failed_requests_metric_total[1h]))",
        "legendFormat": "failed"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 1 }] } } }
    },
    {
      "id": 5,
      "title": "Request Rate by Model",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "sum by (requested_model) (rate(litellm_proxy_total_requests_metric_total[5m]))",
        "legendFormat": "{{requested_model}}"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 6,
      "title": "Latency p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.50, sum(rate(litellm_request_total_latency_metric_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.95, sum(rate(litellm_request_total_latency_metric_bucket[5m])) by (le))", "legendFormat": "p95" },
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.99, sum(rate(litellm_request_total_latency_metric_bucket[5m])) by (le))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 7,
      "title": "Input / Output Tokens per Minute by Model",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "datasource": "Prometheus", "expr": "sum by (model) (rate(litellm_input_tokens_metric_total[1m])) * 60", "legendFormat": "in: {{model}}" },
        { "datasource": "Prometheus", "expr": "sum by (model) (rate(litellm_output_tokens_metric_total[1m])) * 60", "legendFormat": "out: {{model}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 8,
      "title": "LLM API Latency p95 by Model",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "histogram_quantile(0.95, sum by (model, le) (rate(litellm_llm_api_latency_metric_bucket[5m])))",
        "legendFormat": "{{model}}"
      }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ]
}
