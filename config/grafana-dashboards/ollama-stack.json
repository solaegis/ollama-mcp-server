{
  "title": "Ollama Stack",
  "uid": "ollama-stack",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Ollama scrape (Prometheus up)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 4 },
      "targets": [
        {
          "expr": "up{job=\"ollama\"}",
          "legendFormat": "up"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Note",
      "type": "text",
      "gridPos": { "x": 8, "y": 0, "w": 16, "h": 4 },
      "options": {
        "content": "**Ollama + smart router** — the router exposes OpenAI-compatible `/v1` on port **4001**. Prometheus scrapes Ollama `/metrics`; the stat above shows whether that scrape is up.",
        "mode": "markdown"
      }
    }
  ]
}
