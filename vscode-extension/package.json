{
  "name": "ollama-local-llm",
  "displayName": "Ollama Local LLM",
  "description": "Run local LLMs via Ollama directly in VS Code and Cursor. Model picker, quick-prompt panel, send-selection commands.",
  "version": "1.0.0",
  "publisher": "solaegis",
  "repository": {
    "type": "git",
    "url": "https://github.com/solaegis/ollama-mcp-server.git"
  },
  "engines": { "vscode": "^1.85.0" },
  "categories": ["AI", "Other"],
  "keywords": ["ollama", "llm", "local", "ai", "cursor"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ollama.pickModel",
        "title": "Ollama: Switch Model"
      },
      {
        "command": "ollama.sendSelection",
        "title": "Ollama: Send Selection to LLM"
      },
      {
        "command": "ollama.rewriteSelection",
        "title": "Ollama: Rewrite / Improve Selection"
      },
      {
        "command": "ollama.openPanel",
        "title": "Ollama: Open Chat Panel"
      },
      {
        "command": "ollama.pullModel",
        "title": "Ollama: Pull New Model"
      }
    ],
    "configuration": {
      "title": "Ollama Local LLM",
      "properties": {
        "ollama.baseUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama API base URL"
        },
        "ollama.routerUrl": {
          "type": "string",
          "default": "http://localhost:4001",
          "description": "Smart router base URL (OpenAI-compatible /v1; OrbStack: http://router.ollama-stack.orb.local:4001)"
        },
        "ollama.routerBearerToken": {
          "type": "string",
          "default": "sk-local-dev-key",
          "description": "Bearer token sent to the router (placeholder; router does not validate)"
        },
        "ollama.defaultModel": {
          "type": "string",
          "default": "qwen2.5-coder-7b",
          "description": "Default Ollama model id (name:tag)"
        },
        "ollama.temperature": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 2,
          "description": "Sampling temperature"
        }
      }
    },
    "menus": {
      "editor/context": [
        {
          "command": "ollama.sendSelection",
          "when": "editorHasSelection",
          "group": "ollama@1"
        },
        {
          "command": "ollama.rewriteSelection",
          "when": "editorHasSelection",
          "group": "ollama@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "ollama.sendSelection",
        "key": "ctrl+shift+o",
        "mac": "cmd+shift+o",
        "when": "editorHasSelection"
      },
      {
        "command": "ollama.rewriteSelection",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "editorHasSelection"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.1",
    "typescript": "^5.3.0"
  }
}
